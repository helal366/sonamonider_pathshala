model User{
    user_id String @id @default(uuid())
    full_name String
    mobile_number String
    role Role @relation(fields: [role_name], references: [role_name], onDelete: Restrict)
    role_name String

    position_name String
    position Position @relation(fields: [position_name], references: [position_name], onDelete: Restrict)
    gender Gender 
    blood_group BloodGroup?
    date_of_birth DateTime?
    heightInCm Float?
    weightInKg Float?
    religion Religion?
    nationality String?
    birth_certificate_number String?
    nid_number String?
    father_name String?
    mother_name String?
    email String? @unique
    user_name String? 
    user_password String? @default("smps1234")
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@unique([full_name, mobile_number])
    @@map("users")
}