model FatherDetails{
    father_details_id String @id @default(uuid())
    father_name String
    nid_no String?
    occupation String?
    job_title String?
    educational_qualification String?
    monthly_income String?
    mobile_no_1 String?
    mobile_no_2 String?
    mobile_no_3 String?

    created_at DateTime @default(now())
  updated_at DateTime @updatedAt

    user User[] @relation(name: "user_father_details")

    @@map("father_details")
}