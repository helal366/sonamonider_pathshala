model ActiveInactiveHistory {
  active_inactive_history_id String       @id @default(uuid())
  active_status              ActiveStatus
  activationTime             DateTime?
  inactivationTime           DateTime?
  user_id                    String
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  user                       User         @relation("user_active_history", fields: [user_id], references: [user_id])

  @@map("active_inactive_histories")
}
